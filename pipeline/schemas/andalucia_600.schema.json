{
  "document_type": "modelo_600_andalucia",
  "description": "Schema corregido para extracción del Modelo 600 de Andalucía.",
  "extraction_policy": {
    "null_if_missing": true,
    "do_not_infer_unknown_values": true,
    "do_not_calculate_tax_fields_without_source": true,
    "normalize_dates_to": "YYYY-MM-DD",
    "for_legal_entities": "usar razon_social en *_nombre y dejar *_apellido1/*_apellido2 a null"
  },
  "fields": {
    "fecha_devengo": {
      "type": "date",
      "required": true,
      "format": "YYYY-MM-DD",
      "description": "Fecha del devengo del impuesto (firma de escritura, contrato, etc.).",
      "rules": [
        "Es la fecha de la escritura notarial o del documento privado",
        "Puede aparecer como 'En [ciudad] a [día] de [mes] de [año]'"
      ],
      "examples": ["2024-03-12", "2023-11-02"],
      "text_examples": [
        {"text": "En Sevilla a 12 de marzo de 2024", "value": "2024-03-12"}
      ]
    },
    "codigo_territorial": {
      "type": "string",
      "required": false,
      "description": "Código territorial u oficina liquidadora andaluza (provincia o delegación).",
      "rules": [
        "04=Almería, 11=Cádiz, 14=Córdoba, 18=Granada",
        "21=Huelva, 23=Jaén, 29=Málaga, 41=Sevilla"
      ],
      "examples": ["41", "29", "18"],
      "text_examples": [
        {"text": "Inmueble sito en Sevilla", "value": "41"},
        {"text": "Inmueble sito en Málaga", "value": "29"}
      ]
    },
    "concepto": {
      "type": "string",
      "required": true,
      "format": "enum",
      "options": ["TPO", "AJD", "OS"],
      "description": "Concepto principal del modelo 600 andaluz.",
      "rules": [
        "TPO: Transmisiones Patrimoniales Onerosas — compraventas entre particulares de bienes usados",
        "AJD: Actos Jurídicos Documentados — primera transmisión de promotor, hipotecas",
        "OS: Operaciones Societarias"
      ],
      "examples": ["TPO", "AJD"],
      "text_examples": [
        {"text": "ESCRITURA DE COMPRAVENTA (entre particulares, bien usado)", "value": "TPO"}
      ]
    },
    "tipo_acto": {
      "type": "string",
      "required": false,
      "format": "enum",
      "options": ["COMPRAVENTA", "HERENCIA", "DONACION", "DISOLUCION_CONDOMINIO", "HIPOTECA", "OBRA_NUEVA", "CONSTITUCION_SOCIEDAD", "OTRO"],
      "description": "Clasificación material interna del acto.",
      "rules": [],
      "examples": ["COMPRAVENTA", "HERENCIA"],
      "text_examples": [
        {"text": "ESCRITURA DE COMPRAVENTA", "value": "COMPRAVENTA"},
        {"text": "ESCRITURA DE ACEPTACIÓN Y ADJUDICACIÓN DE HERENCIA", "value": "HERENCIA"}
      ]
    },
    "tipo_documento_origen": {
      "type": "string",
      "required": true,
      "format": "enum",
      "options": ["NOTARIAL", "JUDICIAL", "ADMINISTRATIVO", "PRIVADO", "POLIZA_NOTARIAL"],
      "description": "Tipo de documento origen según la clasificación andaluza SURWEB.",
      "rules": [
        "NOTARIAL: escritura pública (lo más habitual)",
        "JUDICIAL: sentencia o auto judicial",
        "ADMINISTRATIVO: resolución de organismo público",
        "PRIVADO: contrato privado sin notario",
        "POLIZA_NOTARIAL: póliza intervenida por notario"
      ],
      "examples": ["NOTARIAL", "PRIVADO"],
      "text_examples": [
        {"text": "Escritura pública otorgada ante Notario", "value": "NOTARIAL"}
      ]
    },
    "adquisicion_gananciales": {
      "type": "boolean",
      "required": false,
      "format": "true_false",
      "description": "Marca si la adquisición se realiza para sociedad de gananciales (matrimonio en régimen ganancial).",
      "rules": ["true solo si los compradores son un matrimonio en gananciales"],
      "examples": ["false", "true"],
      "text_examples": []
    },
    "sujeto_pasivo_nif": {
      "type": "string",
      "required": true,
      "format": "NIF_NIE_CIF",
      "description": "NIF/NIE/CIF del sujeto pasivo principal (comprador, heredero o donatario).",
      "rules": [
        "Formato NIF: 8 dígitos + letra",
        "Formato NIE: X/Y/Z + 7 dígitos + letra"
      ],
      "examples": ["12345678A", "X1234567A"],
      "text_examples": [
        {"text": "COMPRADORA: MARÍA GARCÍA LÓPEZ, con DNI 12345678A", "value": "12345678A"}
      ]
    },
    "sujeto_pasivo_apellido1": {
      "type": "string",
      "required": false,
      "description": "Primer apellido del sujeto pasivo principal.",
      "rules": [],
      "examples": ["GARCÍA"],
      "text_examples": []
    },
    "sujeto_pasivo_apellido2": {
      "type": "string",
      "required": false,
      "description": "Segundo apellido del sujeto pasivo principal.",
      "rules": [],
      "examples": ["LÓPEZ"],
      "text_examples": []
    },
    "sujeto_pasivo_nombre": {
      "type": "string",
      "required": true,
      "description": "Nombre del sujeto pasivo principal o razón social si es persona jurídica.",
      "rules": [],
      "examples": ["MARÍA", "Inversiones XYZ SL"],
      "text_examples": []
    },
    "sujeto_pasivo_domicilio": {
      "type": "string",
      "required": false,
      "format": "direccion_postal",
      "description": "Domicilio del sujeto pasivo principal.",
      "rules": [],
      "examples": ["Calle Mayor 14, 3º A"],
      "text_examples": []
    },
    "sujeto_pasivo_municipio": {
      "type": "string",
      "required": false,
      "description": "Municipio del sujeto pasivo principal.",
      "rules": [],
      "examples": ["Sevilla", "Granada", "Málaga"],
      "text_examples": []
    },
    "sujeto_pasivo_provincia": {
      "type": "string",
      "required": false,
      "description": "Provincia del sujeto pasivo principal.",
      "rules": [],
      "examples": ["Sevilla", "Granada", "Málaga"],
      "text_examples": []
    },
    "sujeto_pasivo_cp": {
      "type": "string",
      "required": false,
      "format": "codigo_postal",
      "description": "Código postal del sujeto pasivo principal.",
      "rules": [],
      "examples": ["41001", "18001"],
      "text_examples": []
    },
    "sujeto_pasivo_porcentaje": {
      "type": "number",
      "required": false,
      "format": "porcentaje_0_100",
      "description": "Porcentaje adquirido por el sujeto pasivo principal.",
      "rules": [],
      "examples": ["100", "50"],
      "text_examples": []
    },
    "otros_sujetos_pasivos": {
      "type": "array",
      "required": false,
      "format": "array<object>",
      "description": "Lista de sujetos pasivos adicionales con nif, nombre y porcentaje.",
      "rules": ["Solo si hay más de un adquirente"],
      "examples": [],
      "text_examples": []
    },
    "transmitente_nif": {
      "type": "string",
      "required": false,
      "format": "NIF_NIE_CIF",
      "description": "NIF/NIE/CIF del transmitente principal (vendedor, causante o donante).",
      "rules": [],
      "examples": ["87654321B"],
      "text_examples": []
    },
    "transmitente_apellido1": {
      "type": "string",
      "required": false,
      "description": "Primer apellido del transmitente principal.",
      "rules": [],
      "examples": ["MARTÍNEZ"],
      "text_examples": []
    },
    "transmitente_apellido2": {
      "type": "string",
      "required": false,
      "description": "Segundo apellido del transmitente principal.",
      "rules": [],
      "examples": ["RUIZ"],
      "text_examples": []
    },
    "transmitente_nombre": {
      "type": "string",
      "required": false,
      "description": "Nombre del transmitente principal o razón social si es persona jurídica.",
      "rules": [],
      "examples": ["PEDRO"],
      "text_examples": []
    },
    "transmitente_domicilio": {
      "type": "string",
      "required": false,
      "format": "direccion_postal",
      "description": "Domicilio del transmitente principal.",
      "rules": [],
      "examples": ["Calle Betis 3, 2º B, Sevilla"],
      "text_examples": []
    },
    "otros_transmitentes": {
      "type": "array",
      "required": false,
      "format": "array<object>",
      "description": "Lista de transmitentes adicionales (si hay más de uno).",
      "rules": [],
      "examples": [],
      "text_examples": []
    },
    "notario": {
      "type": "string",
      "required": false,
      "description": "Nombre y apellidos del notario autorizante.",
      "rules": ["Puede ir precedido de 'ante mí' o 'ante el Notario de'"],
      "examples": ["Juan García López"],
      "text_examples": []
    },
    "numero_protocolo": {
      "type": "string",
      "required": false,
      "description": "Número de protocolo notarial.",
      "rules": [],
      "examples": ["1234"],
      "text_examples": []
    },
    "protocolo_bis": {
      "type": "string",
      "required": false,
      "description": "Sufijo o protocolo bis, si existe.",
      "rules": [],
      "examples": [],
      "text_examples": []
    },
    "ejercicio_protocolo": {
      "type": "string",
      "required": false,
      "format": "YYYY",
      "description": "Año del protocolo notarial.",
      "rules": [],
      "examples": ["2024"],
      "text_examples": []
    },
    "municipio_otorgamiento": {
      "type": "string",
      "required": false,
      "description": "Municipio de otorgamiento del documento (ciudad del notario).",
      "rules": [],
      "examples": ["Sevilla", "Málaga"],
      "text_examples": []
    },
    "inmueble_tipo": {
      "type": "string",
      "required": false,
      "format": "enum",
      "options": ["URBANO", "RUSTICO", "GARAJE", "TRASTERO", "LOCAL", "SOLAR", "OTRO"],
      "description": "Tipo del bien principal.",
      "rules": [],
      "examples": ["URBANO", "RUSTICO"],
      "text_examples": []
    },
    "inmueble_descripcion": {
      "type": "string",
      "required": false,
      "description": "Descripción libre del bien principal.",
      "rules": [],
      "examples": ["Vivienda unifamiliar de 120 m²"],
      "text_examples": []
    },
    "inmueble_referencia_catastral": {
      "type": "string",
      "required": false,
      "format": "referencia_catastral",
      "description": "Referencia catastral del bien principal (20 caracteres).",
      "rules": [],
      "examples": ["0012301DF3800A0001TK"],
      "text_examples": []
    },
    "inmueble_valor_catastral": {
      "type": "number",
      "required": false,
      "format": "importe_eur",
      "description": "Valor catastral si consta expresamente en el documento.",
      "rules": [],
      "examples": ["100000"],
      "text_examples": []
    },
    "inmueble_direccion": {
      "type": "string",
      "required": true,
      "format": "direccion_postal",
      "description": "Dirección del inmueble principal.",
      "rules": ["Puede aparecer después de 'sito en', 'ubicado en', 'situado en'"],
      "examples": ["Calle San Fernando 12, 1ºA, Sevilla"],
      "text_examples": []
    },
    "inmueble_municipio": {
      "type": "string",
      "required": true,
      "description": "Municipio del inmueble principal.",
      "rules": [],
      "examples": ["Sevilla", "Málaga", "Granada"],
      "text_examples": []
    },
    "inmueble_provincia": {
      "type": "string",
      "required": false,
      "description": "Provincia del inmueble principal.",
      "rules": [],
      "examples": ["Sevilla", "Málaga"],
      "text_examples": []
    },
    "inmueble_cp": {
      "type": "string",
      "required": false,
      "format": "codigo_postal",
      "description": "Código postal del inmueble principal.",
      "rules": [],
      "examples": ["41001", "29001"],
      "text_examples": []
    },
    "base_imponible": {
      "type": "number",
      "required": false,
      "format": "importe_eur",
      "description": "Base imponible declarada. Extraer solo si consta expresamente en el documento.",
      "rules": ["NO calcular ni inferir si no aparece explícitamente"],
      "examples": ["150000", "250000"],
      "text_examples": [
        {"text": "por un precio de CIENTO CINCUENTA MIL EUROS (150.000 €)", "value": "150000"}
      ]
    },
    "porcentaje_transmitido": {
      "type": "number",
      "required": false,
      "format": "porcentaje_0_100",
      "description": "Porcentaje del bien transmitido.",
      "rules": [],
      "examples": ["100", "50"],
      "text_examples": []
    },
    "tipo_gravamen": {
      "type": "number",
      "required": false,
      "format": "porcentaje",
      "description": "Tipo de gravamen. No inferir si no consta en el documento.",
      "rules": ["TPO Andalucía: escala 8-9-10% según valor", "AJD: 1,2%"],
      "examples": ["8", "9", "1.2"],
      "text_examples": []
    },
    "cuota_tributaria": {
      "type": "number",
      "required": false,
      "format": "importe_eur",
      "description": "Cuota tributaria. No calcular si no consta expresamente.",
      "rules": [],
      "examples": ["12000"],
      "text_examples": []
    },
    "motivo_no_ingreso": {
      "type": "string",
      "required": false,
      "format": "enum",
      "options": ["NO_APLICA", "01_EXENCION", "04_PRESCRITA", "05_APLAZAMIENTO_FRACCIONAMIENTO", "NO_SUJECION"],
      "description": "Causa de no ingreso cuando no hay cuota a pagar.",
      "rules": [],
      "examples": ["01_EXENCION", "NO_SUJECION"],
      "text_examples": []
    },
    "fundamento_beneficio_fiscal": {
      "type": "string",
      "required": false,
      "description": "Fundamento legal del beneficio fiscal o exención aplicada.",
      "rules": [],
      "examples": ["Art. 45.I.B.4 TRLITPAJD", "Familia numerosa"],
      "text_examples": []
    },
    "tipo_declaracion_complementaria": {
      "type": "string",
      "required": false,
      "format": "enum",
      "options": ["NO_APLICA", "COMPLEMENTARIA", "RECTIFICATIVA", "SUSTITUTIVA"],
      "description": "Tipo de declaración respecto de otra anterior.",
      "rules": ["Solo si se menciona que es complementaria, rectificativa o sustitutiva"],
      "examples": ["COMPLEMENTARIA"],
      "text_examples": []
    },
    "numero_justificante_anterior": {
      "type": "string",
      "required": false,
      "description": "Número de justificante de la autoliquidación anterior si aplica.",
      "rules": [],
      "examples": [],
      "text_examples": []
    },
    "remision_registro": {
      "type": "boolean",
      "required": false,
      "format": "true_false",
      "description": "Marca de remisión al registro cuando proceda.",
      "rules": [],
      "examples": ["true", "false"],
      "text_examples": []
    }
  },
  "output_format": {
    "type": "xml"
  }
}
