{
  "document_type": "modelo_600_murcia",
  "description": "Schema corregido para extracción del Modelo 600 de Murcia / PACO.",
  "extraction_policy": {
    "null_if_missing": true,
    "do_not_infer_unknown_values": true,
    "do_not_calculate_tax_fields_without_source": true,
    "normalize_dates_to": "YYYY-MM-DD",
    "for_legal_entities": "usar razon_social en *_nombre y dejar *_apellido1/*_apellido2 a null"
  },
  "fields": {
    "fecha_devengo": {
      "type": "date",
      "required": true,
      "format": "YYYY-MM-DD",
      "description": "Fecha del devengo del impuesto.",
      "rules": [
        "Es la fecha de la escritura notarial o del documento privado",
        "Puede aparecer como 'En [ciudad] a [día] de [mes] de [año]'"
      ],
      "examples": ["2024-03-12", "2023-11-02"],
      "text_examples": [
        {"text": "En Murcia a 12 de marzo de 2024", "value": "2024-03-12"}
      ]
    },
    "concepto": {
      "type": "string",
      "required": false,
      "format": "enum",
      "options": ["TPO", "AJD", "OS"],
      "description": "Concepto general del impuesto si consta expresamente.",
      "rules": [
        "TPO: Transmisiones Patrimoniales Onerosas",
        "AJD: Actos Jurídicos Documentados",
        "OS: Operaciones Societarias"
      ],
      "examples": ["TPO", "AJD"],
      "text_examples": []
    },
    "tipo_documento_origen": {
      "type": "string",
      "required": true,
      "format": "enum",
      "options": ["PRIVADO", "EXPEDIDO_POR_FUNCIONARIO", "EXPEDIDO_POR_TRIBUNAL_U_ORGANO_DE_JUSTICIA", "NOTARIAL"],
      "description": "Tipo de documento origen según la clasificación oficial de PACO (Región de Murcia).",
      "rules": [
        "NOTARIAL: escritura pública (lo más habitual)",
        "EXPEDIDO_POR_TRIBUNAL_U_ORGANO_DE_JUSTICIA: sentencia o resolución judicial",
        "EXPEDIDO_POR_FUNCIONARIO: documento administrativo",
        "PRIVADO: contrato privado sin notario"
      ],
      "examples": ["NOTARIAL", "PRIVADO"],
      "text_examples": [
        {"text": "Escritura pública otorgada ante Notario", "value": "NOTARIAL"}
      ]
    },
    "tipo_acto": {
      "type": "string",
      "required": false,
      "format": "enum",
      "options": ["COMPRAVENTA", "HERENCIA", "DONACION", "DISOLUCION_CONDOMINIO", "PRESTAMO_HIPOTECARIO", "OBRA_NUEVA", "OTRO"],
      "description": "Clasificación material interna del acto.",
      "rules": [],
      "examples": ["COMPRAVENTA", "HERENCIA"],
      "text_examples": [
        {"text": "ESCRITURA DE COMPRAVENTA", "value": "COMPRAVENTA"}
      ]
    },
    "hecho_imponible_grupo": {
      "type": "string",
      "required": false,
      "description": "Grupo del hecho imponible en PACO.",
      "rules": [],
      "examples": ["I - Transmisiones Patrimoniales Onerosas"],
      "text_examples": []
    },
    "hecho_imponible_codigo": {
      "type": "string",
      "required": false,
      "description": "Código del hecho imponible en PACO.",
      "rules": [],
      "examples": ["TPO-01"],
      "text_examples": []
    },
    "hecho_imponible_descripcion": {
      "type": "string",
      "required": false,
      "description": "Descripción literal del hecho imponible.",
      "rules": [],
      "examples": ["Transmisión de bienes inmuebles"],
      "text_examples": []
    },
    "sujeto_pasivo_nif": {
      "type": "string",
      "required": true,
      "format": "NIF_NIE_CIF",
      "description": "NIF/NIE/CIF del sujeto pasivo principal (comprador, heredero o donatario).",
      "rules": [
        "Formato NIF: 8 dígitos + letra",
        "Formato NIE: X/Y/Z + 7 dígitos + letra"
      ],
      "examples": ["12345678A", "X1234567A"],
      "text_examples": []
    },
    "sujeto_pasivo_apellido1": {
      "type": "string",
      "required": false,
      "description": "Primer apellido del sujeto pasivo principal.",
      "rules": [],
      "examples": ["GARCÍA"],
      "text_examples": []
