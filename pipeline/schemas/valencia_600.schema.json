{
  "document_type": "modelo_600_valencia",
  "description": "Schema corregido para extracción del Modelo 600 de la Comunitat Valenciana.",
  "extraction_policy": {
    "null_if_missing": true,
    "do_not_infer_unknown_values": true,
    "do_not_calculate_tax_fields_without_source": true,
    "normalize_dates_to": "YYYY-MM-DD",
    "for_legal_entities": "usar razon_social en *_nombre y dejar *_apellido1/*_apellido2 a null"
  },
  "fields": {
    "fecha_devengo": {
      "type": "date",
      "required": true,
      "format": "YYYY-MM-DD",
      "description": "Fecha del devengo del impuesto.",
      "rules": [
        "Es la fecha de la escritura notarial o del documento privado",
        "Puede aparecer como 'En [ciudad] a [día] de [mes] de [año]'"
      ],
      "examples": ["2024-03-12", "2026-03-02"],
      "text_examples": [
        {"text": "En Valencia a 12 de marzo de 2024", "value": "2024-03-12"}
      ]
    },
    "concepto": {
      "type": "string",
      "required": true,
      "format": "enum",
      "options": ["0001_TRANS_PATRIMONIALES", "0002_ACTOS_JURIDICOS_DOCUMENTADOS", "0003_OPERACIONES_SOCIETARIAS"],
      "description": "Concepto oficial del formulario valenciano.",
      "rules": [
        "0001_TRANS_PATRIMONIALES: compraventas entre particulares de bienes usados",
        "0002_ACTOS_JURIDICOS_DOCUMENTADOS: primera transmisión de promotor, hipotecas, obras nuevas",
        "0003_OPERACIONES_SOCIETARIAS: ampliaciones o disoluciones de sociedades"
      ],
      "examples": ["0001_TRANS_PATRIMONIALES", "0002_ACTOS_JURIDICOS_DOCUMENTADOS"],
      "text_examples": [
        {"text": "ESCRITURA DE COMPRAVENTA (entre particulares)", "value": "0001_TRANS_PATRIMONIALES"}
      ]
    },
    "organo_gestor": {
      "type": "string",
      "required": false,
      "format": "codigo_y_descripcion",
      "description": "Órgano gestor u oficina liquidadora, por ejemplo 'EH4654 - O.L. ALGEMESI'.",
      "rules": ["Solo si aparece expresamente en el documento"],
      "examples": ["EH4654 - O.L. ALGEMESI"],
      "text_examples": []
    },
    "tipo_acto": {
      "type": "string",
      "required": false,
      "format": "enum",
      "options": ["COMPRAVENTA", "HERENCIA", "DONACION", "DISOLUCION_CONDOMINIO", "HIPOTECA", "OBRA_NUEVA", "OTRO"],
      "description": "Clasificación material interna del negocio.",
      "rules": [],
      "examples": ["COMPRAVENTA", "HERENCIA"],
      "text_examples": [
        {"text": "ESCRITURA DE COMPRAVENTA", "value": "COMPRAVENTA"},
        {"text": "ESCRITURA DE ACEPTACIÓN Y ADJUDICACIÓN DE HERENCIA", "value": "HERENCIA"}
      ]
    },
    "tipo_documento_origen": {
      "type": "string",
      "required": true,
      "format": "enum",
      "options": ["NOTARIAL", "JUDICIAL", "PRIVADO", "OTRO"],
      "description": "Tipo de documento según el desplegable oficial del formulario ATV.",
      "rules": [
        "NOTARIAL: escritura pública (lo más habitual)",
        "JUDICIAL: sentencia o resolución judicial",
        "PRIVADO: contrato privado sin notario",
        "OTRO: resto de casos"
      ],
      "examples": ["NOTARIAL", "PRIVADO"],
      "text_examples": [
        {"text": "Escritura pública otorgada ante Notario", "value": "NOTARIAL"}
      ]
    },
    "notario": {
      "type": "string",
      "required": false,
      "description": "Nombre y apellidos del notario autorizante. Solo si el documento es notarial.",
      "rules": ["Puede ir precedido de 'ante mí' o 'ante el Notario de'"],
      "examples": ["Juan García López"],
      "text_examples": []
    },
    "notario_poblacion": {
      "type": "string",
      "required": false,
      "description": "Población o residencia del notario.",
      "rules": ["Aparece como 'Notario de [ciudad]' o 'con residencia en [ciudad]'"],
      "examples": ["Valencia", "Alicante"],
      "text_examples": []
    },
    "numero_protocolo": {
      "type": "string",
      "required": false,
      "description": "Número de protocolo del documento notarial.",
      "rules": [],
      "examples": ["1234", "567"],
      "text_examples": []
    },
    "numero_protocolo_bis": {
      "type": "string",
      "required": false,
      "description": "Número o sufijo de protocolo bis, si existe.",
      "rules": ["Solo si aparece un segundo número de protocolo o sufijo 'bis'"],
      "examples": [],
      "text_examples": []
    },
    "ejercicio_protocolo": {
      "type": "string",
      "required": false,
      "format": "YYYY",
      "description": "Año del protocolo notarial.",
      "rules": [],
      "examples": ["2024", "2023"],
      "text_examples": []
    },
    "sujeto_pasivo_nif": {
      "type": "string",
      "required": true,
      "format": "NIF_NIE_CIF",
      "description": "NIF/NIE/CIF del sujeto pasivo principal (comprador, heredero o donatario).",
      "rules": [
        "Formato NIF: 8 dígitos + letra",
        "Formato NIE: X/Y/Z + 7 dígitos + letra"
      ],
      "examples": ["12345678A", "X1234567A"],
      "text_examples": [
        {"text": "COMPRADORA: MARÍA GARCÍA LÓPEZ, con DNI 12345678A", "value": "12345678A"}
      ]
    },
    "sujeto_pasivo_apellido1": {
      "type": "string",
      "required": false,
      "description": "Primer apellido del sujeto pasivo si es persona física.",
      "rules": [],
      "examples": ["GARCÍA", "MARTÍNEZ"],
      "text_examples": []
    },
    "sujeto_pasivo_apellido2": {
      "type": "string",
      "required": false,
      "description": "Segundo apellido del sujeto pasivo si es persona física.",
      "rules": [],
      "examples": ["LÓPEZ", "FERNÁNDEZ"],
      "text_examples": []
    },
    "sujeto_pasivo_nombre": {
      "type": "string",
      "required": true,
      "description": "Nombre del sujeto pasivo o razón social si es persona jurídica.",
      "rules": [],
      "examples": ["MARÍA", "JUAN", "Inversiones XYZ SL"],
      "text_examples": []
    },
    "sujeto_pasivo_domicilio": {
      "type": "string",
      "required": false,
      "format": "direccion_postal",
      "description": "Domicilio del sujeto pasivo.",
      "rules": [],
      "examples": ["Calle Colón 14, 3º A"],
      "text_examples": []
    },
    "sujeto_pasivo_municipio": {
      "type": "string",
      "required": false,
      "description": "Municipio del sujeto pasivo.",
      "rules": [],
      "examples": ["Valencia", "Alicante"],
      "text_examples": []
    },
    "sujeto_pasivo_provincia": {
      "type": "string",
      "required": false,
      "description": "Provincia del sujeto pasivo.",
      "rules": [],
      "examples": ["Valencia", "Alicante"],
      "text_examples": []
    },
    "sujeto_pasivo_cp": {
      "type": "string",
      "required": false,
      "format": "codigo_postal",
      "description": "Código postal del sujeto pasivo.",
      "rules": [],
      "examples": ["46001", "03001"],
      "text_examples": []
    },
    "sujeto_pasivo_porcentaje": {
      "type": "number",
      "required": false,
      "format": "porcentaje_0_100",
      "description": "Porcentaje adquirido por el sujeto pasivo principal.",
      "rules": ["Normalmente 100 si es el único adquirente"],
      "examples": ["100", "50"],
      "text_examples": []
    },
    "transmitente_nif": {
      "type": "string",
      "required": false,
      "format": "NIF_NIE_CIF",
      "description": "NIF/NIE/CIF del transmitente principal (vendedor, causante o donante).",
      "rules": [],
      "examples": ["87654321B"],
      "text_examples": []
    },
    "transmitente_apellido1": {
      "type": "string",
      "required": false,
      "description": "Primer apellido del transmitente si es persona física.",
      "rules": [],
      "examples": ["MARTÍNEZ"],
      "text_examples": []
    },
    "transmitente_apellido2": {
      "type": "string",
      "required": false,
      "description": "Segundo apellido del transmitente si es persona física.",
      "rules": [],
      "examples": ["RUIZ"],
      "text_examples": []
    },
    "transmitente_nombre": {
      "type": "string",
      "required": false,
      "description": "Nombre del transmitente o razón social si es persona jurídica.",
      "rules": [],
      "examples": ["PEDRO"],
      "text_examples": []
    },
    "transmitente_domicilio": {
      "type": "string",
      "required": false,
      "format": "direccion_postal",
      "description": "Domicilio del transmitente principal.",
      "rules": [],
      "examples": ["Calle Paz 3, 2º B, Valencia"],
      "text_examples": []
    },
    "inmueble_tipo": {
      "type": "string",
      "required": false,
      "format": "enum",
      "options": ["URBANO", "RUSTICO", "GARAJE", "TRASTERO", "LOCAL", "SOLAR", "OTRO"],
      "description": "Tipo del bien principal.",
      "rules": [],
      "examples": ["URBANO", "RUSTICO"],
      "text_examples": []
    },
    "inmueble_descripcion": {
      "type": "string",
      "required": false,
      "description": "Descripción libre del bien principal.",
      "rules": ["Incluye tipo, superficie, planta, referencia registral si aparece"],
      "examples": ["Vivienda unifamiliar de 120 m²"],
      "text_examples": []
    },
    "inmueble_referencia_catastral": {
      "type": "string",
      "required": false,
      "format": "referencia_catastral",
      "description": "Referencia catastral del bien principal (20 caracteres alfanuméricos).",
      "rules": [],
      "examples": ["0012301YJ2701A0001TK"],
      "text_examples": []
    },
    "inmueble_valor_catastral": {
      "type": "number",
      "required": false,
      "format": "importe_eur",
      "description": "Valor catastral si aparece expresamente en el documento.",
      "rules": ["Solo el número, sin símbolo de moneda"],
      "examples": ["80000", "120000"],
      "text_examples": []
    },
    "inmueble_direccion": {
      "type": "string",
      "required": true,
      "format": "direccion_postal",
      "description": "Dirección del inmueble principal.",
      "rules": ["Puede aparecer después de 'sito en', 'ubicado en', 'situado en'"],
      "examples": ["Calle Colón 12, 1ºA, Valencia"],
      "text_examples": []
    },
    "inmueble_municipio": {
      "type": "string",
      "required": true,
      "description": "Municipio del inmueble principal.",
      "rules": [],
      "examples": ["Valencia", "Alicante", "Benidorm"],
      "text_examples": []
    },
    "inmueble_provincia": {
      "type": "string",
      "required": false,
      "description": "Provincia del inmueble principal.",
      "rules": [],
      "examples": ["Valencia", "Alicante", "Castellón"],
      "text_examples": []
    },
    "inmueble_cp": {
      "type": "string",
      "required": false,
      "format": "codigo_postal",
      "description": "Código postal del inmueble principal.",
      "rules": [],
      "examples": ["46001", "03001"],
      "text_examples": []
    },
    "base_imponible": {
      "type": "number",
      "required": false,
      "format": "importe_eur",
      "description": "Base imponible declarada. Extraer solo si consta expresamente en el documento.",
      "rules": [
        "En compraventa: el precio pactado",
        "NO calcular ni inferir si no aparece explícitamente"
      ],
      "examples": ["150000", "250000"],
      "text_examples": [
        {"text": "por precio de CIENTO CINCUENTA MIL EUROS (150.000 €)", "value": "150000"}
      ]
    },
    "porcentaje_transmitido": {
      "type": "number",
      "required": false,
      "format": "porcentaje_0_100",
      "description": "Porcentaje del bien transmitido.",
      "rules": ["Normalmente 100 si se transmite la totalidad"],
      "examples": ["100", "50"],
      "text_examples": []
    },
    "tipo_gravamen": {
      "type": "number",
      "required": false,
      "format": "porcentaje",
      "description": "Tipo de gravamen. No inferir si no consta en el documento.",
      "rules": ["TPO general Comunitat Valenciana: 10%", "AJD: 1,5%"],
      "examples": ["10", "8", "1.5"],
      "text_examples": []
    },
    "cuota_tributaria": {
      "type": "number",
      "required": false,
      "format": "importe_eur",
      "description": "Cuota tributaria. No calcular en esta fase si no consta expresamente.",
      "rules": [],
      "examples": ["15000"],
      "text_examples": []
    },
    "motivo_no_ingreso": {
      "type": "string",
      "required": false,
      "format": "enum",
      "options": ["NO_APLICA", "EXENCION", "NO_SUJECION", "PRESCRITA", "APLAZAMIENTO_FRACCIONAMIENTO"],
      "description": "Motivo de no ingreso o ausencia de cuota.",
      "rules": ["Solo si hay un motivo explícito para no ingresar"],
      "examples": ["EXENCION", "NO_SUJECION"],
      "text_examples": []
    },
    "beneficio_fiscal": {
      "type": "string",
      "required": false,
      "description": "Descripción del beneficio fiscal o fundamento legal.",
      "rules": [],
      "examples": ["Vivienda habitual familia numerosa", "Exención art. 45.I.B.4"],
      "text_examples": []
    },
    "presentador_nif": {
      "type": "string",
      "required": false,
      "format": "NIF_NIE_CIF",
      "description": "NIF/NIE/CIF del presentador o gestor.",
      "rules": [],
      "examples": ["12345678A", "B12345678"],
      "text_examples": []
    },
    "presentador_nombre": {
      "type": "string",
      "required": false,
      "description": "Nombre o razón social del presentador.",
      "rules": [],
      "examples": ["MAM Solicitors SL"],
      "text_examples": []
    },
    "es_complementaria": {
      "type": "boolean",
      "required": false,
      "format": "true_false",
      "description": "Marca si la autoliquidación es complementaria.",
      "rules": ["true solo si se menciona explícitamente"],
      "examples": ["false", "true"],
      "text_examples": []
    },
    "numero_justificante_anterior": {
      "type": "string",
      "required": false,
      "description": "Número de justificante anterior si es complementaria.",
      "rules": [],
      "examples": [],
      "text_examples": []
    }
  },
  "output_format": {
    "type": "xml"
  }
}
